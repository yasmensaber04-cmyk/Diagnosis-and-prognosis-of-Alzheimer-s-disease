    # تطبيق SMOTE
    smote = SMOTE(sampling_strategy='auto', random_state=SEED, k_neighbors=3)
    Xtr_smote, Ytr_smote = smote.fit_resample(Xtr_enhanced, original_labels)
    print(f"     After SMOTE: {Xtr_smote.shape[0]} samples")
    print(f"     New label distribution: CN={np.sum(Ytr_smote==0)}, MCI={np.sum(Ytr_smote==1)}, AD={np.sum(Ytr_smote==2)}")

    # 🆕 Two-stage classifier for MCI
    print("\n  🆕 Training Two-Stage MCI Classifier...")

    cw = [2.0, MCI_WEIGHT, 1.0]  # زيادة وزن MCI
    avg_feat = torch.tensor(Xtr2, dtype=torch.float32).mean(dim=0).to(device)

    all_model_probs = []
    all_results = []
    all_curves = []


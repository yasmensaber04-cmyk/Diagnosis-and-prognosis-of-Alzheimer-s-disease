class M5_Improved_MetaFusion(nn.Module):
    def __init__(self, input_dim):
        super().__init__()
        self.net = nn.Sequential(
            KANLayer(input_dim, 256),
            nn.BatchNorm1d(256),
            nn.Dropout(0.5),
            nn.SiLU(),
            KANLayer(256, 128),
            nn.BatchNorm1d(128),
            nn.Dropout(0.4),
            nn.SiLU(),
            KANLayer(128, 64),
            nn.Dropout(0.3),
            nn.SiLU(),
            nn.Linear(64, 3)
        )
        
    def forward(self, x):
        return self.net(x)


# 🆕 TIME-SPECIFIC XGBoost with optimized params for 36 months
class M4_TimeSpecific_XGBoost:
    def __init__(self):
        self.models = {}
        self.feature_selectors = {}
        
    def fit(self, enhanced_emb_tr, Y_tr):
        for horizon_idx, horizon_name in enumerate(HORIZON_NAMES):
            y_horizon = Y_tr[:, horizon_idx]
            
            if horizon_name == "36 Months":
                selector = SelectKBest(f_classif, k=50)
                X_selected = selector.fit_transform(enhanced_emb_tr, y_horizon)
                self.feature_selectors[horizon_name] = selector
                params = {
                    'n_estimators': 150,
                    'max_depth': 4,
                    'learning_rate': 0.02,
                    'subsample': 0.5,
                    'colsample_bytree': 0.5,
                    'reg_alpha': 0.5,
                    'reg_lambda': 2.0,
                    'min_child_weight': 5,
                    'random_state': SEED + horizon_idx
                }
            elif horizon_name in ["24 Months"]:
                selector = SelectKBest(f_classif, k=100)
                X_selected = selector.fit_transform(enhanced_emb_tr, y_horizon)
                self.feature_selectors[horizon_name] = selector
                params = {
                    'n_estimators': 250,
                    'max_depth': 6,
                    'learning_rate': 0.03,
                    'subsample': 0.7,
                    'colsample_bytree': 0.7,
                    'reg_alpha': 0.1,
                    'reg_lambda': 1.0,
                    'random_state': SEED + horizon_idx
                }
            else:
                X_selected = enhanced_emb_tr
                params = {
                    'n_estimators': 200,
                    'max_depth': 6,
                    'learning_rate': 0.05,
                    'subsample': 0.8,
                    'colsample_bytree': 0.8,
                    'random_state': SEED + horizon_idx
                }
            
            self.models[horizon_name] = xgb.XGBClassifier(**params, eval_metric="mlogloss")
            self.models[horizon_name].fit(X_selected, y_horizon)
        return self
    
    def predict_proba(self, enhanced_emb, horizon_idx):
        horizon_name = HORIZON_NAMES[horizon_idx]
        model = self.models[horizon_name]
        if horizon_name in self.feature_selectors:
            X_input = self.feature_selectors[horizon_name].transform(enhanced_emb)
        else:
            X_input = enhanced_emb
        return model.predict_proba(X_input)


# 🆕 LONG-TERM FEATURES for 36 months
def extract_long_term_features(patient):
    features = []
    if len(patient) >= 12:
        first_half = patient[:6].mean(axis=0)
        second_half = patient[6:].mean(axis=0)
        long_term_trend = (second_half - first_half) / 6
        features.extend(long_term_trend)
    else:
        features.extend(np.zeros(patient.shape[1]))
    
    if len(patient) >= 9:
        early_rate = (patient[4] - patient[0]) / 4 if len(patient) > 4 else np.zeros(patient.shape[1])
        late_rate = (patient[-1] - patient[-5]) / 4 if len(patient) > 5 else np.zeros(patient.shape[1])
        long_acceleration = late_rate - early_rate
        features.extend(long_acceleration)
    else:
        features.extend(np.zeros(patient.shape[1]))
    
    if len(patient) >= 8:
        first_trend = np.sign(patient[2] - patient[0])
        last_trend = np.sign(patient[-1] - patient[-3])
        trend_change = last_trend - first_trend
        features.extend(trend_change)
    else:
        features.extend(np.zeros(patient.shape[1]))
    
    long_term_std = patient.std(axis=0) if len(patient) > 0 else np.zeros(patient.shape[1])
    features.extend(long_term_std)
    
    return np.array(features)


# 🆕 MCI-SPECIFIC FEATURES
def extract_mci_specific_features(patient, feature_names):
    """
    ميزات خاصة لاكتشاف وتحول MCI
    """
    features = []
    
    # قائمة الميزات المعرفية
    cognitive_feats = ["MMSE", "ADAS13", "ADAS11", "CDRSB", "FAQ", "MOCA"]
    cognitive_indices = [i for i, f in enumerate(feature_names) if any(c in f for c in cognitive_feats)]
    
    for idx in cognitive_indices:
        values = patient[:, idx]
        if len(values) > 1:
            decline_rate = (values[-1] - values[0]) / len(values)
            features.append(decline_rate)
            if len(values) > 4:
                early_decline = (values[3] - values[0]) / 3
                late_decline = (values[-1] - values[-4]) / 3
                acceleration = late_decline - early_decline
                features.append(acceleration)
        else:
            features.extend([0, 0])
    
    # ميزة ضمور الحصين (Hippocampus atrophy)
    if "Hippocampus" in feature_names:
        hippo_idx = feature_names.index("Hippocampus")
        hippo_values = patient[:, hippo_idx]
        if len(hippo_values) > 1:
            hippo_atrophy_rate = (hippo_values[0] - hippo_values[-1]) / len(hippo_values)
            features.append(hippo_atrophy_rate)
        else:
            features.append(0)
    
    # ميزات عوامل الخطر
    risk_factors = ["APOE4", "PTAU_UPENNBIOMK9", "ABETA_UPENNBIOMK9"]
    risk_score = 0
    risk_count = 0
    for rf in risk_factors:
        if rf in feature_names:
            rf_idx = feature_names.index(rf)
            risk_score += patient[-1, rf_idx]
            risk_count += 1
    if risk_count > 0:
        features.append(risk_score / risk_count)
    else:
        features.append(0)
    
    return np.array(features)


# 🆕 SLIDING WINDOWS for MCI pattern recognition
def extract_mci_temporal_windows(patient_sequence, window_sizes=[3, 6, 9]):
    features = []
    seq_len = len(patient_sequence)
    
    for window_size in window_sizes:
        if seq_len >= window_size:
            last_window = patient_sequence[-window_size:]
            window_mean = last_window.mean(axis=0)
            window_std = last_window.std(axis=0)
            window_trend = (last_window[-1] - last_window[0]) / window_size if window_size > 0 else np.zeros(patient_sequence.shape[1])
            features.extend([window_mean, window_std, window_trend])
        else:
            features.extend([np.zeros(patient_sequence.shape[1]), np.zeros(patient_sequence.shape[1]), np.zeros(patient_sequence.shape[1])])
    
    return np.hstack(features)


# 🆕 ENHANCED TEMPORAL FEATURES (with long-term and MCI-specific)
def extract_enhanced_features_v3(X, feature_names):
    """
    نسخة محسنة من استخراج الميزات تشمل المدى الطويل وميزات MCI
    """
    enhanced_features = []
    
    for patient in X:
        # الميزات الأساسية (قصيرة المدى)
        last_visit = patient[-1]
        differences = np.diff(patient, axis=0)
        
        if len(differences) > 0:
            mean_rate = differences.mean(axis=0)
            std_rate = differences.std(axis=0)
            trend = np.sign(differences).mean(axis=0)
        else:
            mean_rate = np.zeros(patient.shape[1])
            std_rate = np.zeros(patient.shape[1])
            trend = np.zeros(patient.shape[1])
        
        if len(differences) > 1:
            acceleration = np.diff(differences, axis=0).mean(axis=0)
        else:
            acceleration = np.zeros_like(mean_rate)
        
        stability = patient.std(axis=0)
        mean_patient = patient.mean(axis=0)
        deviations = np.abs(patient - mean_patient).max(axis=0)
        
        if len(differences) >= 3:
            last_3_diffs = differences[-3:].flatten()
        elif len(differences) > 0:
            last_3_diffs = np.pad(differences.flatten(), (0, 3*len(mean_rate) - len(differences.flatten())), 'constant')
        else:
            last_3_diffs = np.zeros(3*len(mean_rate))
        
        # ميزات المدى الطويل
        long_term = extract_long_term_features(patient)
        
        # 🆕 ميزات MCI الخاصة
        mci_specific = extract_mci_specific_features(patient, feature_names)
        
        # 🆕 النوافذ الزمنية
        windows = extract_mci_temporal_windows(patient)
        
        # دمج جميع الميزات
        patient_features = np.hstack([
            last_visit,           # 34
            mean_rate,            # 34
            std_rate,             # 34
            acceleration,         # 34
            trend,                # 34
            stability,            # 34
            deviations,           # 34
            last_3_diffs,         # 102
            long_term,            # 136 (4 × 34)
            mci_specific,         # ~19
            windows               # 306 (3 × 3 × 34)
        ])
        
        enhanced_features.append(patient_features)
    
    return np.array(enhanced_features)


# 🆕 TWO-STAGE CLASSIFIER FOR MCI (FIXED)
class TwoStageMCI_Classifier:
    """
    Two-Stage Classifier specialized for MCI detection
    Stage 1: CN vs (MCI+AD)
    Stage 2: MCI vs AD (binary)
    """
    def __init__(self):
        self.stage1_model = None
        self.stage2_model = None
        self.stage1_threshold = 0.5
        
    def fit(self, X, Y):
        print(f"     Training Stage 1: CN vs Abnormal...")
        # Stage 1: Binary classification (CN=0, Abnormal=1)
        y_stage1 = (Y > 0).astype(int)
        
        self.stage1_model = xgb.XGBClassifier(
            n_estimators=150,
            max_depth=4,
            learning_rate=0.05,
            objective='binary:logistic',
            random_state=SEED,
            scale_pos_weight=1.5,
            eval_metric='logloss',
            use_label_encoder=False
        )
        self.stage1_model.fit(X, y_stage1)
        
        # Stage 2: Only for abnormal cases, classify MCI vs AD
        abnormal_mask = y_stage1 == 1
        if abnormal_mask.sum() > 0:
            print(f"     Training Stage 2: MCI vs AD (n={abnormal_mask.sum()})...")
            X_stage2 = X[abnormal_mask]
            Y_stage2 = Y[abnormal_mask]
            
            # Convert: MCI=0, AD=1 for binary classification
            Y_stage2_binary = (Y_stage2 == 2).astype(int)
            
            self.stage2_model = xgb.XGBClassifier(
                n_estimators=150,
                max_depth=5,
                learning_rate=0.05,
                objective='binary:logistic',
                random_state=SEED,
                scale_pos_weight=1.0,
                eval_metric='logloss',
                use_label_encoder=False
            )
            self.stage2_model.fit(X_stage2, Y_stage2_binary)
        else:
            print("     Warning: No abnormal samples found for Stage 2!")
            self.stage2_model = None
            
        return self
    
    def predict_proba(self, X):
        # Stage 1 prediction
        prob_stage1 = self.stage1_model.predict_proba(X)
        # prob_stage1[:, 0] = P(CN)
        # prob_stage1[:, 1] = P(Abnormal)
        
        final_probs = np.zeros((X.shape[0], 3))
        
        # Cases predicted as normal
        normal_mask = prob_stage1[:, 0] > self.stage1_threshold
        final_probs[normal_mask, 0] = prob_stage1[normal_mask, 0]
        final_probs[normal_mask, 1] = prob_stage1[normal_mask, 1] * 0.5
        final_probs[normal_mask, 2] = prob_stage1[normal_mask, 1] * 0.5
        
        # Cases predicted as abnormal
        abnormal_mask = ~normal_mask
        if abnormal_mask.sum() > 0 and self.stage2_model is not None:
            prob_stage2 = self.stage2_model.predict_proba(X[abnormal_mask])
            # prob_stage2[:, 0] = P(MCI)
            # prob_stage2[:, 1] = P(AD)
            
            abnormal_prob = prob_stage1[abnormal_mask, 1]
            final_probs[abnormal_mask, 1] = prob_stage2[:, 0] * abnormal_prob
            final_probs[abnormal_mask, 2] = prob_stage2[:, 1] * abnormal_prob
            final_probs[abnormal_mask, 0] = 1 - abnormal_prob
            
            # Normalize to ensure sum = 1
            row_sum = final_probs[abnormal_mask].sum(axis=1)
            final_probs[abnormal_mask] = final_probs[abnormal_mask] / row_sum[:, np.newaxis]
        
        return final_probs


class LongHorizonEnsemble:
    def __init__(self):
        self.weights = {
            "24 Months": {"m4": 0.7, "m5": 0.3},
            "36 Months": {"m4": 0.6, "m5": 0.4}
        }
        
    def predict(self, horizon_idx, m4_probs, m5_probs):
        horizon_name = HORIZON_NAMES[horizon_idx]
        if horizon_name in self.weights:
            w = self.weights[horizon_name]
            return w["m4"] * m4_probs + w["m5"] * m5_probs
        else:
            return m4_probs



                                epochs=100, lr=1e-3, cw=cw, patience=10, tag="M1-GAT")
    all_curves.append(("M1 — GATv2", tr1, va1))
    m1_probs, _ = get_probs(m1, Xte)
    all_model_probs.append(m1_probs)
    print("\n  📊 M1 Results:")
    all_results += evaluate(m1_probs, Yte, "M1_GATv2")
    del m1; gc.collect()

    # ── PHASE 2b: M2 — BiLSTM+Transformer ───────────────────────────────────

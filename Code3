def train_torch(model, Xtr, Ytr, Xval, Yval,
                epochs=120, lr=1e-4, cw=None, patience=12, tag="Model"):
    weights = torch.tensor(cw if cw else [1., 1., 1.]).to(device)
    opt = optim.AdamW(model.parameters(), lr=lr, weight_decay=0.01)
    sch = optim.lr_scheduler.CosineAnnealingLR(opt, T_max=epochs)

    xt = torch.tensor(Xtr, dtype=torch.float32).to(device)
    yt = torch.tensor(Ytr).to(device)
    xv = torch.tensor(Xval, dtype=torch.float32).to(device)
    yv = torch.tensor(Yval).to(device)

    best_loss, best_state, trigger = float("inf"), None, 0
    tr_losses, va_losses = [], []

    for ep in range(1, epochs + 1):
        model.train(); opt.zero_grad()
        outs, _ = model(xt)
        loss = sum(F.cross_entropy(outs[j], yt[:, j], weight=weights, label_smoothing=0.1)
                   for j in range(4))
        loss.backward(); opt.step(); sch.step()
        tr_losses.append(loss.item())

        model.eval()
        with torch.no_grad():
            vo, _ = model(xv)
            vloss = sum(F.cross_entropy(vo[j], yv[:, j]) for j in range(4))
            va_losses.append(vloss.item())

        if vloss < best_loss:
            best_loss = vloss.item()
            best_state = {k: v.clone() for k, v in model.state_dict().items()}
            trigger = 0
        else:
            trigger += 1
            if trigger >= patience:
                print(f"    ↩ Early stop @ epoch {ep}")
                break

        if ep % 30 == 0:
            print(f"    [{tag}] Ep {ep:03d} | Train {loss.item():.4f} | Val {vloss.item():.4f}")

    model.load_state_dict(best_state)
    return model, tr_losses, va_losses


def train_torch_improved(model, Xtr, Ytr, Xval, Yval,
                         epochs=150, lr=1e-4, cw=None, patience=15, tag="Model"):
    weights = torch.tensor(cw if cw else [1., 1., 1.]).to(device)
    opt = optim.AdamW(model.parameters(), lr=lr, weight_decay=0.01)
    sch = optim.lr_scheduler.CosineAnnealingLR(opt, T_max=epochs)
    horizon_weights = torch.tensor(HORIZON_WEIGHTS).to(device)

    xt = torch.tensor(Xtr, dtype=torch.float32).to(device)
    yt = torch.tensor(Ytr).to(device)
    xv = torch.tensor(Xval, dtype=torch.float32).to(device)
    yv = torch.tensor(Yval).to(device)

    best_loss, best_state, trigger = float("inf"), None, 0
    tr_losses, va_losses = [], []

    for ep in range(1, epochs + 1):
        model.train(); opt.zero_grad()
        outs, _ = model(xt)
        loss = sum(horizon_weights[j] * F.cross_entropy(outs[j], yt[:, j], weight=weights, label_smoothing=0.1)
                   for j in range(4))
        loss.backward(); opt.step(); sch.step()
        tr_losses.append(loss.item())

        model.eval()
        with torch.no_grad():
            vo, _ = model(xv)
            vloss = sum(F.cross_entropy(vo[j], yv[:, j]) for j in range(4))
            va_losses.append(vloss.item())

        if vloss < best_loss:
            best_loss = vloss.item()
            best_state = {k: v.clone() for k, v in model.state_dict().items()}
            trigger = 0
        else:
            trigger += 1
            if trigger >= patience:
                print(f"    ↩ Early stop @ epoch {ep}")
                break

        if ep % 30 == 0:
            print(f"    [{tag}] Ep {ep:03d} | Train {loss.item():.4f} | Val {vloss.item():.4f}")

    model.load_state_dict(best_state)
    return model, tr_losses, va_losses


def get_probs(model, X):
    model.eval()
    with torch.no_grad():
        outs, emb = model(torch.tensor(X, dtype=torch.float32).to(device))
    return [F.softmax(o, dim=1).cpu().numpy() for o in outs], emb



def evaluate(probs_list, Yte, name):
    results = []
    for i, (probs, hn) in enumerate(zip(probs_list, HORIZON_NAMES)):
        preds = np.argmax(probs, axis=1)
        yt    = Yte[:, i]
        ybin  = label_binarize(yt, classes=[0, 1, 2])

        acc = accuracy_score(yt, preds) * 100
        f1m = f1_score(yt, preds, average="macro", zero_division=0) * 100
        f1w = f1_score(yt, preds, average="weighted", zero_division=0) * 100
        fpc = f1_score(yt, preds, average=None, zero_division=0) * 100

        try:
            am = roc_auc_score(ybin, probs, average="macro", multi_class="ovr") * 100
            aw = roc_auc_score(ybin, probs, average="weighted", multi_class="ovr") * 100
        except Exception:
            am = aw = 0.0

        apc = []
        for c in range(3):
            if ybin[:, c].sum() > 0:
                fpr, tpr, _ = roc_curve(ybin[:, c], probs[:, c])
                apc.append(auc(fpr, tpr) * 100)
            else:
                apc.append(0.0)

        cm = confusion_matrix(yt, preds, labels=[0, 1, 2])
        results.append({
            "model": name, "horizon": hn,
            "acc": acc, "f1_macro": f1m, "f1_weighted": f1w,
            "auc_macro": am, "auc_weighted": aw,
            "f1_CN": fpc[0] if len(fpc) > 0 else 0,
            "f1_MCI": fpc[1] if len(fpc) > 1 else 0,
            "f1_AD": fpc[2] if len(fpc) > 2 else 0,
            "auc_CN": apc[0], "auc_MCI": apc[1], "auc_AD": apc[2],
            "cm": cm, "probs": probs, "preds": preds
        })
        print(f"  {name:<26s} | {hn:<12s} | Acc:{acc:5.1f}% | F1:{f1m:5.1f}% | AUC:{am:5.1f}%")
    return results



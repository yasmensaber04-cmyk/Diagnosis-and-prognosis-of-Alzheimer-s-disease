    print("\n  📊 M4b Results (reference — not in final comparison):")
    _ = evaluate(m4b_probs, Yte, "M4b_XGB_LastVisit")

    # ── PHASE 2f: M5 — Improved DeepMetaFusion ───────────────────────────────
    print("\n" + "─" * 70)
    print("🤝   PHASE 2f — M5: Improved DeepMetaFusion (M3 + M4)")
    m5_probs = []
    for i in range(4):
        m4_probs_tr_i = m4_improved.predict_proba(Xtr_enhanced, i)
        m_tr_i = np.hstack([m3_probs_tr[i], m4_probs_tr_i])
        m_te_i = np.hstack([m3_probs_te[i], m4_improved_probs[i]])

        meta = M5_Improved_MetaFusion(m_tr_i.shape[1]).to(device)
        mopt = optim.Adam(meta.parameters(), lr=0.01, weight_decay=0.001)
        
        yt_i = torch.tensor(Ytr[:, i]).to(device)
        mt_t = torch.tensor(m_tr_i, dtype=torch.float32).to(device)
        
        best_loss = float('inf')
        patience = 20
        trigger = 0
        
        horizon_weight = HORIZON_WEIGHTS[i]
        
        for ep in range(300):
            mopt.zero_grad()
            loss = horizon_weight * F.cross_entropy(meta(mt_t), yt_i, label_smoothing=0.05)
            loss.backward()
            mopt.step()
            
            if loss.item() < best_loss:
                best_loss = loss.item()
                trigger = 0
            else:
                trigger += 1
                if trigger >= patience:
                    break

        meta.eval()
        with torch.no_grad():
            logits = meta(torch.tensor(m_te_i, dtype=torch.float32).to(device))
            m5_probs.append(F.softmax(logits, dim=1).cpu().numpy())

    all_model_probs.append(m5_probs)
    print("\n  📊 M5 Results (Improved MetaFusion):")
    all_results += evaluate(m5_probs, Yte, "M5_MetaFusion_Improved_V2")


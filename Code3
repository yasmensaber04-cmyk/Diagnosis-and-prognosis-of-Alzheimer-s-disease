class KANLayer(nn.Module):
    def __init__(self, in_f, out_f):
        super().__init__()
        self.base_linear   = nn.Linear(in_f, out_f)
        self.spline_weight = nn.Parameter(torch.randn(out_f, in_f) * 0.1)

    def forward(self, x):
        return self.base_linear(x) + F.silu(x) @ self.spline_weight.t()


class M1_GATv2(nn.Module):
    def __init__(self, input_dim, hidden=128):
        super().__init__()
        self.gnn      = GATv2Conv(input_dim, hidden // 4, heads=4, dropout=0.3)
        self.gnn_norm = GraphNorm(hidden)
        self.pool     = nn.AdaptiveAvgPool1d(1)
        self.heads    = nn.ModuleList([KANLayer(hidden, 3) for _ in range(4)])
        self.register_buffer("edge_index", None)

    def forward(self, x):
        b, t, _ = x.shape
        xg = self.gnn_norm(self.gnn(x.view(b * t, -1), self.edge_index)).view(b, t, -1)
        ctx = self.pool(xg.permute(0, 2, 1)).squeeze(-1)
        return [h(ctx) for h in self.heads], ctx

    def build_edges(self, x_avg, top_k=4):
        with torch.no_grad():
            nm  = x_avg.norm(dim=1, keepdim=True)
            sim = torch.mm(x_avg, x_avg.t()) / (torch.mm(nm, nm.t()) + 1e-8)
            edges = [[i, j.item()] for i in range(sim.shape[0]) 
                     for j in torch.topk(sim[i], k=top_k + 1).indices[1:]]
            self.edge_index = torch.tensor(edges).t().contiguous().to(device)


class M2_BiLSTM_Transformer(nn.Module):
    def __init__(self, input_dim, hidden=256, n_layers=3):
        super().__init__()
        self.proj = nn.Linear(input_dim, hidden)
        self.lstm = nn.LSTM(hidden, hidden // 2, bidirectional=True, batch_first=True, dropout=0.3)
        enc = nn.TransformerEncoderLayer(d_model=hidden, nhead=8, dim_feedforward=512, batch_first=True, dropout=0.3)
        self.transformer = nn.TransformerEncoder(enc, num_layers=n_layers)
        self.attn  = nn.Linear(hidden, 1)
        self.heads = nn.ModuleList([KANLayer(hidden, 3) for _ in range(4)])

    def forward(self, x):
        x   = self.proj(x)
        xl, _ = self.lstm(x)
        xt  = self.transformer(xl)
        w   = torch.softmax(self.attn(xt), dim=1)
        ctx = (w * xt).sum(dim=1)
        return [h(ctx) for h in self.heads], ctx


class M3_BrainSovereign_KAN(nn.Module):
    def __init__(self, input_dim, hidden=512, n_layers=6):
        super().__init__()
        self.gnn      = GATv2Conv(input_dim, hidden // 4, heads=4, dropout=0.4)
        self.gnn_norm = GraphNorm(hidden)
        self.lstm     = nn.LSTM(hidden, hidden // 2, bidirectional=True, batch_first=True, dropout=0.4)
        enc = nn.TransformerEncoderLayer(d_model=hidden, nhead=8, dim_feedforward=2048, batch_first=True, dropout=0.4)
        self.transformer = nn.TransformerEncoder(enc, num_layers=n_layers)
        self.attn  = nn.Linear(hidden, 1)
        self.heads = nn.ModuleList([KANLayer(hidden, 3) for _ in range(4)])
        self.register_buffer("edge_index", None)

    def forward(self, x):
        b, t, _ = x.shape
        xg = self.gnn_norm(self.gnn(x.view(b * t, -1), self.edge_index)).view(b, t, -1)
        xl, _ = self.lstm(xg)
        xt    = self.transformer(xl)
        w     = torch.softmax(self.attn(xt), dim=1)
        ctx   = (w * xt).sum(dim=1)
        return [h(ctx) for h in self.heads], ctx

    def build_edges(self, x_avg, top_k=4):
        with torch.no_grad():
            nm  = x_avg.norm(dim=1, keepdim=True)
            sim = torch.mm(x_avg, x_avg.t()) / (torch.mm(nm, nm.t()) + 1e-8)
            edges = [[i, j.item()] for i in range(sim.shape[0]) 
                     for j in torch.topk(sim[i], k=top_k + 1).indices[1:]]
            self.edge_index = torch.tensor(edges).t().contiguous().to(device)



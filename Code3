def run_shap_patient(xgb_flat_model, patient_last_visit, feat_names,
                     patient_idx, horizon_name, predicted_class):
    try:
        explainer  = shap.TreeExplainer(xgb_flat_model)
        sv         = explainer.shap_values(patient_last_visit.reshape(1, -1))
        sv_class   = (sv[predicted_class][0] if isinstance(sv, list) else
                      (sv[0] if len(sv.shape) > 1 else sv))
        if hasattr(sv_class, "shape") and len(sv_class.shape) > 1:
            sv_class = sv_class.flatten()

        fi = sorted([{"feature": n, "shap_value": float(v), "abs_shap": abs(float(v))}
                     for n, v in zip(feat_names, sv_class)],
                    key=lambda x: x["abs_shap"], reverse=True)
        return fi
    except Exception as e:
        print(f"    ⚠ Patient SHAP failed: {e}")
        return []



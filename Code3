    demo       = ["AGE","APOE4","PTEDUCAT","PTGENDER"]
    dti_cols   = [c for c in df.columns if "DTI" in c]
    feats = [f for f in (structural + biomarkers + cognitive + demo + dti_cols)
             if f in df.columns]

    print(f"  ✅ Features found: {len(feats)}")
    print(f"     Structural:{len([f for f in structural if f in df.columns])}  "
          f"Biomarkers:{len([f for f in biomarkers if f in df.columns])}  "
          f"Cognitive:{len([f for f in cognitive if f in df.columns])}  "
          f"Demo:{len([f for f in demo if f in df.columns])}  "
          f"DTI:{len(dti_cols)}")

    clin = [c for c in ["MMSE","ADAS13","CDRSB","FAQ","Hippocampus","WholeBrain"]
            if c in df.columns]
    plt.figure(figsize=(9, 7))
    sns.heatmap(df[clin].corr(), annot=True, cmap="RdBu_r", center=0,
                fmt=".2f", linewidths=0.5)
    plt.title("Clinical Feature Correlation Matrix", fontsize=13, fontweight="bold")
    plt.tight_layout()
    plt.savefig("clinical_correlation.png", dpi=150)
    plt.close()

    df[feats] = RobustScaler().fit_transform(df[feats])

    X, Y = [], []
    for rid in df["RID"].unique():
        p = df[df["RID"] == rid]
        if len(p) < 5:
            continue
        raw  = p[feats].values
        base = raw[:-4]
        pad  = (np.pad(base, ((seq_len - len(base), 0), (0, 0)), mode="edge")
                if len(base) < seq_len else base[-seq_len:])
        X.append(pad)
        Y.append([p["DX_num"].iloc[-4], p["DX_num"].iloc[-3],
                  p["DX_num"].iloc[-2], p["DX_num"].iloc[-1]])

    X, Y = np.array(X), np.array(Y).astype(int)

    max_s = min(pd.Series(Y[:, 0]).value_counts().max(), 500)
    Xb, Yb = [], []
    for cv in np.unique(Y[:, 0]):
        xf, yf = resample(X[Y[:, 0] == cv], Y[Y[:, 0] == cv],
                          n_samples=max_s, random_state=SEED)
        Xb.append(xf); Yb.append(yf)
    Xa, Ya = np.vstack(Xb), np.vstack(Yb)

    Xtr, Xte, Ytr, Yte = train_test_split(Xa, Ya, test_size=0.15, random_state=SEED)
    print(f"  Train: {Xtr.shape[0]}  |  Test: {Xte.shape[0]}  |  "
          f"Seq:{seq_len}  Features:{len(feats)}")
    return Xtr, Xte, Ytr, Yte, feats


